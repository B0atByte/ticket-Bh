# ── Server ──────────────────────────────────────────────
PORT=8787
# Optional shared secret. If set, the extension must send the same value as the
# `x-api-key` header (configure it in the extension popup). Leave blank to allow
# any local caller (fine for a single-user desktop setup).
API_KEY=

# ── Google service account ──────────────────────────────
# Path to the downloaded service-account JSON key file (see README).
# The service account email must be granted edit access to the Sheet, and the
# Drive folder must be shared with it as well.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ── Google Sheet ────────────────────────────────────────
# The spreadsheet ID is the long token in the sheet URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SHEET_ID=
# Tab (worksheet) name to write into. Created/headed automatically if empty.
SHEET_TAB=Orders

# ── Google Drive (screenshots) ──────────────────────────
# Folder ID to store screenshots in (from the folder URL). If blank, screenshots
# are uploaded to the service account's Drive root. Share the folder with the
# service account email so it can write into it.
DRIVE_FOLDER_ID=
