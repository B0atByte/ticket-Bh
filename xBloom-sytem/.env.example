# ── MySQL ───────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=xbloom
MYSQL_USER=xbloom
MYSQL_PASSWORD=change_me_app
MYSQL_PORT=3306

# ── Backend API (Hono) ──────────────────────────────────
API_PORT=8080
# DB connection used by the API container (host = mysql service name)
DATABASE_URL=mysql://xbloom:change_me_app@mysql:3306/xbloom
# JWT secret — DO NOT commit the real value. In production use a long random
# string (>=24 chars, no "dev/change/secret"), e.g. `openssl rand -hex 32`.
JWT_SECRET=change_me_jwt_secret
# Allowed browser origins (comma-separated). Leave EMPTY in dev to allow all.
# In production set to your site origin(s), e.g. https://service.xbloom.co.th
CORS_ORIGINS=

# ── Email notifications (optional; leave blank to disable) ──
# Gmail/Workspace: turn on 2-Step Verification, then create an App Password
# (Google account → Security → App passwords) and use it as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=xBloom Thailand <your@gmail.com>

# ── AI assist (optional; DeepSeek, OpenAI-compatible) ──
# Drafts bilingual customer replies in the staff CRM. Leave blank to disable.
# The key is used server-side only. Get one at platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Shopee export (optional) ────────────────────────────
# Orders scraped by the browser extension ALWAYS save to the platform DB and
# show in Staff CRM → Shopee. To ALSO mirror them into a Google Sheet (and
# upload screenshots to Drive), set the values below. Leave blank to keep
# everything inside the platform only.
#   1. Google Cloud → enable Sheets API + Drive API → create a service account
#      → download its JSON key → save it as ./shopee-service-account.json
#   2. Share your Google Sheet (and Drive folder) with the service-account
#      email (xxx@yyy.iam.gserviceaccount.com) as Editor.
#   3. Set the path below and uncomment the matching volume mount in
#      docker-compose.yml (api service). In Docker use the container path:
#      GOOGLE_APPLICATION_CREDENTIALS=/app/backend/shopee-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=
SHOPEE_SHEET_ID=
SHOPEE_SHEET_TAB=Orders
SHOPEE_DRIVE_FOLDER_ID=
# Optional shared secret the extension must send (set the same value in the
# extension popup's "API Key"). Leave blank to accept without a key.
SHOPEE_API_KEY=

# ── Frontend (Vite) ─────────────────────────────────────
FRONTEND_PORT=5173
# The browser always calls same-origin /api; the Vite dev server (and nginx in
# prod) proxy it to the API. So LAN clients work without knowing the API host
# and there is no CORS. No VITE_API_URL needed here — it is set to /api by compose.

# ── Production only (docker-compose.prod.yml) ───────────
# Public port the nginx frontend listens on.
WEB_PORT=80
