NODE_ENV=development
PORT=4000

# === Database ===
DATABASE_URL="mysql://lms_user:change-me@localhost:3306/lms"

# === Redis ===
REDIS_URL="redis://:change-me-redis@localhost:6379"

# === JWT ===
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET="replace-with-strong-secret-min-32-chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# === Security ===
BCRYPT_ROUNDS=12
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
MUTATION_RATE_LIMIT_MAX=120

# === Mail (Phase 4) ===
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="LMS Casa <noreply@example.com>"

# === Storage (Phase 3) ===
STORAGE_DRIVER="local"          # local | s3 | minio
STORAGE_LOCAL_PATH="./uploads"
S3_ENDPOINT=""
S3_REGION="ap-southeast-1"
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# === Observability ===
LOG_LEVEL="info"
SENTRY_DSN=""

# === Report Issue (แจ้งปัญหา) ===
# Discord webhook to notify when someone submits the "แจ้งปัญหา" button — optional, leave empty to disable
DISCORD_WEBHOOK_URL=""

# Shared secret required in the X-Dashboard-Key header for GET /api/v1/issues (used by issues-dashboard)
DASHBOARD_API_KEY=""

# === AI question generation (optional) ===
# Priority: DeepSeek → OpenAI → local fallback (ถ้าว่างทั้งคู่)
# DeepSeek (แนะนำ — ถูกกว่า OpenAI ~10 เท่า)
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
# OpenAI (ใช้ถ้าไม่มี DeepSeek key)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# === SSO / OIDC (Phase 6) ===
# Leave OIDC_ISSUER empty to disable SSO entirely.
# Azure AD:  https://login.microsoftonline.com/<tenant-id>/v2.0
# Google:    https://accounts.google.com
# Keycloak:  https://your-keycloak/realms/your-realm
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_REDIRECT_URI="http://localhost:4000/api/v1/auth/oidc/callback"
# true = auto-create account on first SSO login; false = require pre-existing account
OIDC_AUTO_PROVISION=false
