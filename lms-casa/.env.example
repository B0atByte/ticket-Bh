# Root .env (used by docker-compose)
# Copy to .env and adjust for your environment

# === MySQL ===
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=lms
MYSQL_USER=lms_user
MYSQL_PASSWORD=change-me
MYSQL_PORT=3306

# === Redis ===
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis

# === Server (proxied to server container) ===
SERVER_PORT=4000

# === Client ===
CLIENT_PORT=5173
