PORT=4003

# Comma-separated list of every frontend origin allowed to POST an issue
# directly from the browser. Add one per system as you wire it up (see
# README "Frontend wiring checklist").
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:8083"

# Shared secret issues-dashboard sends as X-Dashboard-Key when pulling
# GET /api/issues. Generate with: openssl rand -hex 32
DASHBOARD_API_KEY=

# ── Per-system Discord webhooks (all optional — unset = no notification for that system) ──
DISCORD_WEBHOOK_BHLOGISTICSSYSTEM=
DISCORD_WEBHOOK_PRSYSTEM=
DISCORD_WEBHOOK_LMSCASA=
DISCORD_WEBHOOK_XBLOOM=
DISCORD_WEBHOOK_QSCSYTEM=
