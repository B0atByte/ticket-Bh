PORT=4002
FRONTEND_URL="http://localhost:5177"

# Sign the dashboard's own login session — unrelated to any of the 5 systems' JWT secrets.
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-string-min-32-chars"

# Single shared admin password for this dashboard, stored as a bcrypt hash (never plaintext).
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=""

# ── Per-system source config ────────────────────────────────────────────
# Base URL of each system's backend + the X-Dashboard-Key it expects (must
# match the DASHBOARD_API_KEY set in that system's own .env exactly).

BHLOGISTICS_BASE_URL="http://localhost:4001"
BHLOGISTICS_API_KEY=""

PRSYSTEM_BASE_URL="http://localhost:3000"
PRSYSTEM_API_KEY=""

LMSCASA_BASE_URL="http://localhost:4000"
LMSCASA_API_KEY=""

XBLOOM_BASE_URL="http://localhost:8080"
XBLOOM_API_KEY=""

# NOTE: QSC-Sytem's docker-compose also maps host port 8080 by default —
# if running both xBloom and QSC at once, change one of their host ports.
QSC_BASE_URL="http://localhost:8080"
QSC_API_KEY=""
